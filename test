  }

  .product-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .product-price {
    font-size: 22px;
    font-weight: 700;
    color: #2563eb;
    white-space: nowrap;
  }

  .btn-add {
    padding: 10px 20px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .btn-add:hover {
    background: #1d4ed8;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37,99,235,0.3);
  }

  .btn-add:active {
    transform: translateY(0);
  }

  /* Tablet and below */
  @media (max-width: 1200px) {
    .product-card {
      min-width: calc(33.333% - 16px);
      max-width: calc(33.333% - 16px);
    }
  }

  @media (max-width: 900px) {
    .product-card {
      min-width: calc(50% - 12px);
      max-width: calc(50% - 12px);
    }

    .section-title {
      font-size: 28px;
    }

    .page-inner {
      padding: 0 30px;
    }

    .slider-container {
      padding: 0 15px;
    }

    .arrow-btn {
      width: 44px;
      height: 44px;
    }

    .arrow-btn.prev-btn {
      left: 8px;
    }

    .arrow-btn.next-btn {
      right: 8px;
    }
  }


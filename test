  @media (max-width: 640px) {
    .featured-section,
    .newarrivals-section {
      padding: 30px 0;
      border-radius: 12px;
      margin-bottom: 40px;
    }

    .page-inner {
      padding: 0 20px;
    }

    .section-head {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 24px;
    }

    .section-title {
      font-size: 24px;
      margin-bottom: 4px;
    }

    .section-lead {
      font-size: 14px;
    }

    .section-controls {
      width: 100%;
      justify-content: center;
    }

    .product-card {
      min-width: 100%;
      max-width: 100%;
    }

    .slider-container {
      padding: 0 10px;
      min-height: 450px;
    }

    .slider-wrapper {
      gap: 16px;
    }

    .arrow-btn {
      width: 40px;
      height: 40px;
      font-size: 16px;
    }

    .arrow-btn.prev-btn {
      left: 5px;
    }

    .arrow-btn.next-btn {
      right: 5px;
    }

    .product-body {
      padding: 16px;
    }

    .product-title {
      font-size: 15px;
      min-height: 40px;
      margin-bottom: 10px;
    }

    .product-price {
      font-size: 20px;
    }

    .btn-add {
      padding: 8px 16px;
      font-size: 13px;
    }
  }

  /* Extra small mobile */
  @media (max-width: 380px) {
    .arrow-btn {
      width: 36px;
      height: 36px;
      font-size: 14px;
    }

    .product-foot {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .btn-add {
      width: 100%;
      text-align: center;
    }
  }

/* ===================================================================
   INSTAGRAM / SOCIAL GRID
   =================================================================== */
.instagram-section { padding:36px 16px; }
.instagram-section .page-inner { max-width:1200px; margin:0 auto; }

.insta-head .section-title { margin:0; font-size:20px; font-weight:900; }
.insta-head .section-lead { margin:4px 0 0; color:var(--muted); }

.insta-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap:10px;
  align-items:stretch;
}

.insta-tile {
  display:block;
  border:0;
  background:transparent;
  padding:0;
  overflow:hidden;
  position:relative;
  cursor:pointer;
  border-radius:10px;
  -webkit-tap-highlight-color: transparent;
}
.insta-tile img {
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  transition: transform .36s cubic-bezier(.2,.9,.2,1), filter .36s ease;
  aspect-ratio: 1 / 1;
  background: linear-gradient(180deg,#f3f3f4,#ffffff);
}

.insta-tile:hover img,
.insta-tile:focus img { transform: scale(1.06); filter: contrast(1.02) saturate(1.02); outline: none; }

.insta-tile[data-index="0"],
.insta-tile[data-index="3"] { grid-column: span 2; grid-row: span 2; }

@media (max-width:1200px) {
  .insta-grid { grid-template-columns: repeat(4, 1fr); }
}
@media (max-width:900px) {
  .insta-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width:640px) {
  .insta-grid { grid-template-columns: repeat(2, 1fr); gap:8px; }
  .insta-tile[data-index="0"], .insta-tile[data-index="3"] { grid-column: span 2; grid-row: span 1; }
}
@media (max-width:420px) {
  .insta-grid { grid-template-columns: 1fr 1fr; gap:6px; }
}

.insta-lightbox {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(2,6,23,0.78);
  z-index: 1400;
  padding: 20px;
}
.insta-lightbox[aria-hidden="false"] { display:flex; }

.lb-stage {
  max-width: 1100px;
  width:100%;
  max-height: 88vh;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  gap:12px;
  padding: 12px;
  background: transparent;
}
.lb-stage img { max-width:100%; max-height:78vh; object-fit:contain; border-radius:8px; background:#fff; }

.lb-close, .lb-prev, .lb-next {
  position: absolute;
  border:0;
  background:#fff;
  color:#000;
  width:44px;height:44px;border-radius:8px;cursor:pointer;box-shadow:0 8px 22px rgba(2,6,23,0.06);
  display:flex;align-items:center;justify-content:center;font-weight:800;
}
.lb-close { right:18px; top:18px; }
.lb-prev { left:12px; top:50%; transform:translateY(-50%); }
.lb-next { right:12px; top:50%; transform:translateY(-50%); }

@media (max-width:640px){
  .lb-close, .lb-prev, .lb-next { width:40px;height:40px; }
  .lb-prev { left:8px; }
  .lb-next { right:8px; }
}

.insta-tile:focus { outline: 3px solid rgba(0,0,0,0.06); outline-offset:6px; }
.lb-stage:focus { outline: none; }

#lbCaption { color:var(--muted); font-size:14px; text-align:center; max-width:80%; }
#lbCredit { color:var(--muted); font-size:13px; }

/* ===================================================================
   MISSION / VALUES / TRUST
   =================================================================== */
.mission-section {
  padding: 22px 14px;
  background: #fff;
  color: var(--accent);
}
.mission-section .page-inner { max-width:1200px; margin:0 auto; }

.mission-head { margin-bottom:14px; display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
.section-title { margin:0; font-size:20px; font-weight:900; line-height:1.03; }
.section-lead { margin-top:6px; color:var(--muted); font-size:14px; max-width:66ch; }

.mission-grid { display:grid; grid-template-columns: 1fr; gap:12px; margin:18px 0; }
.mission-card {
  display:flex;
  gap:12px;
  align-items:flex-start;
  background:#fff;
  border-radius:12px;
  padding:12px;
  border:1px solid rgba(2,6,23,0.04);
  box-shadow: 0 8px 26px rgba(2,6,23,0.03);
  transition: transform .16s ease, box-shadow .16s ease;
}
.mission-card:focus-within, .mission-card:focus { transform: translateY(-6px); box-shadow:0 18px 50px rgba(2,6,23,0.06); outline: none; }

.m-icon {
  min-width:56px;
  min-height:56px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:12px;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  color: var(--accent);
  flex-shrink:0;
  box-shadow: 0 4px 12px rgba(2,6,23,0.04);
}

.m-icon svg {
  width: 24px;
  height: 24px;
  stroke-width: 2;
}

.m-title { margin:0; font-size:15px; font-weight:900; }
.m-text { margin:0; color:var(--muted); font-size:13px; line-height:1.45; }

.trust-row { display:flex; flex-direction:column; gap:12px; margin-top:12px; align-items:flex-start; justify-content:space-between; }
.trust-stats { display:flex; gap:18px; align-items:flex-start; flex-wrap:wrap; }
.stat { display:flex; flex-direction:column; gap:6px; min-width:120px; }
.stat-num { font-size:20px; font-weight:900; color:var(--accent); }
.stat-label { font-size:13px; color:var(--muted); }

.trust-badges { display:flex; gap:10px; align-items:center; margin-top:6px; }
.badge { width:48px; height:32px; display:flex; align-items:center; justify-content:center; background:#fafafa; border-radius:8px; border:1px solid rgba(2,6,23,0.03); color:var(--accent); }

@media (min-width:760px) {
  .mission-grid { grid-template-columns: repeat(3, 1fr); gap:18px; margin:22px 0; }
  .mission-card { flex-direction:column; align-items:flex-start; padding:18px; min-height:170px; }
  .m-icon { margin-bottom:6px; }
  .trust-row { flex-direction:row; align-items:center; gap:18px; justify-content:space-between; }
  .trust-stats { gap:28px; }
}

@media (min-width:1100px) {
  .section-title { font-size:22px; }
  .stat-num { font-size:22px; }
  .m-text { font-size:14px; }
}
@media (max-width:420px) {
  .section-title { font-size:18px; }
  .stat-num { font-size:18px; }
  .m-text { font-size:13px; }
  .mission-card { padding:12px; gap:10px; }
}

/* ===================================================================
   HEADER, NAV, DRAWER, FOOTER (consolidated & kept selectors)
   =================================================================== */

/* Header variables already defined above */
.site-header{
  position:fixed;
  inset:0 0 auto 0;
  height:var(--header-height);
  display:flex;
  align-items:center;
  background:var(--white);
  border-bottom:1px solid #f3f4f6;
  box-shadow: 0 6px 18px rgba(2,6,23,0.03);
  z-index:1200;
}
.container{width:100%;max-width:1200px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;position:relative}

.nav-group{display:flex;gap:8px;align-items:center}
.nav-item{position:relative}

.btn{background:transparent;border:0;padding:8px 12px;border-radius:8px;cursor:pointer;font-weight:600;color:var(--black);font-size:14px}
.btn:hover{background:#f8fafc}
.btn.primary{background:var(--primary);color:var(--white);padding:8px 14px}

.brand-wrap{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  align-items:center;
  gap:10px;
  pointer-events:none;
  max-width:60%;
  justify-content:center;
  z-index:1190;
}
.brand{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--black);overflow:hidden;pointer-events:auto}
.brand img{height:44px;max-height:calc(var(--header-height) - 20px);width:auto;display:block;max-width:100%;object-fit:contain}
.brand-text{font-weight:800;font-size:18px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

.dropdown{position:absolute;top:calc(100% + 8px);left:0;min-width:220px;background:var(--white);border:1px solid #e6e7eb;border-radius:10px;box-shadow:0 10px 30px rgba(2,6,23,0.06);padding:8px 6px;display:none}
.dropdown a{display:block;padding:8px 12px;color:var(--black);text-decoration:none;border-radius:6px;font-size:14px}
.dropdown a:hover{background:#f8fafc}
.nav-item:focus-within .dropdown,.nav-item:hover .dropdown{display:block}

.cart{display:flex;align-items:center;gap:8px;border:0;background:transparent;padding:6px 8px;border-radius:8px;cursor:pointer}
.cart svg{display:block}
.cart-badge{min-width:20px;height:20px;border-radius:999px;background:var(--black);color:var(--white);display:inline-flex;align-items:center;justify-content:center;font-size:12px}

.hamburger{
  display:none;
  background:transparent;border:0;padding:8px;border-radius:8px;cursor:pointer;
  z-index:1275;
  position:relative;
}

.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.35);opacity:0;visibility:hidden;transition:opacity .2s ease;z-index:1250}
.drawer-overlay.open{opacity:1;visibility:visible}

.drawer{position:fixed;left:0;top:0;height:100vh;width:min(320px,90%);background:var(--white);transform:translateX(-100%);transition:transform .28s cubic-bezier(.2,.9,.2,1);z-index:1260;padding:16px 18px;display:flex;flex-direction:column;box-shadow: 12px 0 30px rgba(2,6,23,0.06)}
.drawer.open{transform:translateX(0)}
.drawer .close{align-self:flex-end;border:0;background:transparent;padding:6px;cursor:pointer}
.drawer nav{margin-top:12px;display:flex;flex-direction:column;gap:6px;flex:1;overflow:auto;padding-bottom:12px}
.drawer a{padding:12px;border-radius:8px;text-decoration:none;color:var(--black);font-weight:700}
.drawer .sub{padding-left:12px;font-weight:600;display:none;flex-direction:column;gap:6px;margin-bottom:6px}
.drawer .sub a{font-weight:600;padding:8px 6px}
.drawer .sub.open{display:flex}

.drawer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px solid #f3f4f6;margin-top:12px}
.drawer-bottom .account{display:flex;align-items:center;gap:10px}
.drawer-bottom .account svg{width:20px;height:20px}
.drawer-bottom .cart-mini{display:flex;align-items:center;gap:8px}
.drawer-bottom .cart-mini .cart-badge{min-width:20px;height:20px}

.header-spacer{height:var(--header-height)}

/* responsive adjustments */
@media (min-width:1200px){ .brand-wrap{max-width:55%} }
@media (max-width:900px){ .brand-wrap{max-width:65%} }
@media (max-width:600px){ .brand img{height:40px} .brand-text{display:none} .brand-wrap{max-width:75%} }

@media (min-width:901px){
  .hamburger{display:none}
  .nav-left{display:flex}
  .nav-right{display:flex;align-items:center;gap:8px}
  .cart{display:flex}
}
@media (max-width:900px) and (min-width:601px){
  .nav-left{display:none}
  .nav-right{display:none}
  .hamburger{display:inline-flex}
  .cart{display:flex}
}
@media (max-width:600px){
  .nav-left{display:none}
  .nav-right{display:none}
  .hamburger{display:inline-flex}
  .cart{display:none}
  .brand-text{font-size:16px}
}

/* ===================================================================
   FOOTER
   =================================================================== */
.site-footer{background:var(--bg);border-top:1px solid #eef2f6;padding:var(--pad)}
.inner{max-width:var(--max);margin:0 auto;padding:0 20px}

.grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:28px;align-items:start}
.brand{display:flex;gap:14px;align-items:center}
.brand img{height:56px;width:auto;display:block}
.brand-title{font-size:18px;margin:0}
.brand-desc{color:var(--muted);margin-top:8px;line-height:1.5}

.group h4{margin:0 0 12px 0;font-size:15px}
.group ul{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px}
.group a{color:var(--muted);text-decoration:none}
.group a:hover{color:var(--text)}

.newsletter h4{margin:0 0 10px 0}
.newsletter p{margin:0 0 12px 0;color:var(--muted)}
.subscribe{display:flex;gap:10px}
.subscribe input{flex:1;padding:10px;border-radius:8px;border:1px solid #eef2f6;background:#fafbfc}
.subscribe button{padding:10px 14px;border-radius:8px;background:var(--accent);color:var(--bg);border:0;cursor:pointer}

.payments{display:flex;gap:12px;margin-top:12px;align-items:center}
.pay-chip{width:48px;height:32px;display:inline-flex;align-items:center;justify-content:center;border-radius:6px;background:#fff;border:1px solid #f1f5f9}
.social{display:flex;gap:10px;margin-top:12px}
.social a{width:36px;height:36px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;border:1px solid #f1f5f9}

.bottom{margin-top:26px;border-top:1px solid #f3f4f6;padding-top:18px;display:flex;justify-content:space-between;align-items:center;gap:12px}
.muted{color:var(--muted);font-size:13px}

@media (max-width:1000px){
  .grid{grid-template-columns:1fr 1fr}
  .brand img{height:52px}
}
@media (max-width:640px){
  .grid{grid-template-columns:1fr}
  .brand img{height:48px}
  .subscribe{flex-direction:column}
  .subscribe button{width:100%}
  .payments{gap:8px}
  .pay-chip{width:44px;height:28px}
  .bottom{flex-direction:column;align-items:flex-start}
}

/* ===================================================================
   SMALL UI / UTILITY IMPROVEMENTS
   =================================================================== */

/* Step labels for upload UI */
.upload-card .form-label { display: flex; align-items: center; gap: 8px; font-size: 15px; }
.upload-card .form-label::before {
    content: counter(step-counter);
    counter-increment: step-counter;
    background-color: #f0f2f5;
    color: var(--muted);
    font-weight: 700;
    font-size: 13px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-grid;
    place-items: center;
}
body { counter-reset: step-counter; }

/* Active states */
.option-btn.active, .color-swatch.active { transform: scale(1.05); }

/* Modal transitions (further refinement) */
.na-modal-close {
    border:0; background:transparent; font-size:24px; cursor:pointer;
    position: absolute; top: 8px; right: 12px; padding: 8px;
    color: var(--muted); line-height: 1;
}

/* Shop page tweaks */
#shopGrid { margin-top: 10px; }
.na-card { min-height: 320px; display:flex; flex-direction:column; justify-content:flex-end; }
#shopFilters { flex-wrap:wrap; gap:8px; }
#shopFilters select, #shopFilters input[type="search"] { min-width:120px; }

/* Quick view modal z-index/layout */
#quickViewModal .na-modal-inner { max-width:960px; }
@media (max-width:980px) {
  #quickViewModal .na-modal-inner { padding:12px; max-width:92%; }
}

/* Accessibility: visible focus */
a:focus, button:focus { outline: 3px solid rgba(0,0,0,0.08); outline-offset:4px; border-radius:6px; }

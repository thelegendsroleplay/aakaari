<!-- FEATURED PRODUCTS SLIDER -->
<section id="section-featured" class="section featured-section" aria-label="Featured products">
  <div class="page-inner">
    <div class="featured-head">
      <div>
        <h2 class="section-title">Featured</h2>
        <p class="section-lead muted">Hand-picked pieces — trending now.</p>
      </div>
      <div class="featured-controls">
        <div class="dots" aria-hidden="true"></div>
        <div class="arrows">
          <button class="prev" aria-label="Previous featured">◀</button>
          <button class="next" aria-label="Next featured">▶</button>
        </div>
      </div>
    </div>
    <div id="featuredSlider" class="featured-slider" tabindex="0"
      aria-roledescription="carousel" aria-live="polite">
      <div class="slides">
        {% assign featured_collection = collections['featured'] | default: collections.all %}
        {% for product in featured_collection.products limit: 8 %}
        <article class="featured-item" role="group" tabindex="0" 
          data-sku="{{ product.variants.first.sku }}" 
          data-slug="{{ product.handle }}"
          data-variant-id="{{ product.variants.first.id }}"
          data-product-id="{{ product.id }}">
          <a href="{{ product.url }}" class="fi-link">
            <div class="fi-media" aria-hidden="true">
              <img src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" loading="lazy" width="800" height="800">
            </div>
            <div class="fi-body">
              <h3 class="fi-title">{{ product.title }}</h3>
              <div class="fi-foot">
                <div class="fi-price">{{ product.price | money }}</div>
                <button class="btn-primary fi-add" type="button" data-variant-id="{{ product.variants.first.id }}">Add to cart</button>
              </div>
            </div>
          </a>
        </article>
        {% else %}
        <div class="featured-placeholder">No featured products available</div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

  <!-- NEW ARRIVALS -->
  <section id="section-newarrivals" class="section newarrivals-section" aria-label="New arrivals">
    <div class="page-inner">
      <div class="new-head" style="display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:18px">
        <div>
          <h2 class="section-title">New arrivals</h2>
          <p class="section-lead muted">Fresh drops — limited quantities. Grab them before they're gone.</p>
        </div>
        <div>
          <a href="/collections/all?sort_by=created-descending" class="btn-primary small">See all new</a>
        </div>
      </div>
<div class="na-grid" id="naGrid" role="list" aria-live="polite" aria-label="New arrivals">
  {% assign new_collection = collections['new-arrivals'] | default: collections.all %}
  {% for product in new_collection.products limit: 6 %}
  {% assign is_new = false %}
  {% assign days_old = 'now' | date: '%s' | minus: product.created_at | date: '%s' | divided_by: 86400 %}
  {% if days_old <= 7 %}{% assign is_new = true %}{% endif %}
  
  <article class="na-card" role="listitem" tabindex="0" 
    data-sku="{{ product.variants.first.sku }}" 
    data-name="{{ product.title | escape }}" 
    data-price="{{ product.price | money_without_currency }}"
    data-images='{{ product.images | map: "src" | json }}'>
    <a class="na-inner-link" href="{{ product.url }}">
      <div class="na-media">
        <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title }}" loading="lazy">
        {% if is_new %}
        <span class="na-badge">New</span>
        {% elsif product.tags contains 'featured' %}
        <span class="na-badge">Featured</span>
        {% endif %}
      </div>
      <div class="na-body">
      <h3 class="na-title">{{ product.title }}</h3>
      <div class="na-foot">
          <div class="na-price">{{ product.price | money }}</div>
          <div class="na-actions">
            <button class="btn-ghost na-quick" type="button">Quick view</button>
            <button class="btn-primary na-add" type="button">Add</button>
          </div>
        </div>
      </div>
    </a>
  </article>
  {% else %}
  <div class="na-placeholder">No new arrivals available</div>
  {% endfor %}
</div>
    </div>
  </section>
